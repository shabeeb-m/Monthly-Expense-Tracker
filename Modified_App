server <- function(input, output, session){
  
  current_tab <- reactiveVal("home")
  refresh_data <- reactiveVal(0)
  
  observeEvent(input$nav_home, { current_tab("home") })
  observeEvent(input$nav_analysis, { current_tab("analysis") })
  observeEvent(input$nav_emi, { current_tab("emi") })
  observeEvent(input$view_budget, { current_tab("budget") })
  observeEvent(input$view_txn, { current_tab("transactions") })
  observeEvent(input$back, { current_tab("home") })
  
  # 📥 READ SHEET
  sheet_data <- reactive({
    refresh_data()
    
    df <- read_sheet(sheet_url, sheet = sheet_tab)
    
    df <- df %>%
      mutate(
        Date = as.Date(Date),
        Expense = as.numeric(Expense)
      ) %>%
      filter(!is.na(Date))
    
    df$MonthYear <- format(df$Date, "%b %Y")
    df$MonthYearDate <- as.Date(format(df$Date, "%Y-%m-01"))
    
    df
  })
  
  # ➕ ADD MODAL
  observeEvent(input$nav_add, {
    showModal(modalDialog(
      title = "Add Expense",
      
      dateInput("date", "Date", value = Sys.Date()),
      selectizeInput("cat","Category",
                     choices=budget_df$Category,
                     options=list(create=TRUE)),
      textInput("sub","Sub Category"),
      numericInput("amt","Amount", value = NA, min=0),
      
      footer = tagList(
        modalButton("Cancel"),
        actionButton("save_modal","Save", class="btn-success")
      )
    ))
  })
  
  # 💾 SAVE
  observeEvent(input$save_modal, {
    
    req(input$date, input$cat, input$amt)
    
    if(is.na(input$amt) || input$amt <= 0){
      showNotification("Enter valid amount", type="error")
      return()
    }
    
    new_row <- data.frame(
      Date = as.Date(input$date),
      Month = format(as.Date(input$date), "%b"),
      Category = input$cat,
      `Sub-Category` = input$sub,
      Expense = input$amt,
      stringsAsFactors = FALSE
    )
    
    sheet_append(sheet_url, new_row, sheet = sheet_tab)
    
    removeModal()
    showNotification("Saved ✅")
    refresh_data(refresh_data() + 1)
  })
  
  # 🗑️ DELETE MODAL OPEN
  observeEvent(input$delete_open, {
    showModal(modalDialog(
      title = "Delete Expenses",
      DTOutput("delete_table"),
      footer = tagList(
        modalButton("Cancel"),
        actionButton("confirm_delete", "Delete Selected",
                     style="background:red;color:white;")
      ),
      size = "l"
    ))
  })
  
  today_change <- reactive({
    
    df <- sheet_data()
    
    today_total <- df %>%
      filter(Date == Sys.Date()) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    yesterday_total <- df %>%
      filter(Date == Sys.Date() - 1) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    if(is.na(yesterday_total) || yesterday_total == 0){
      return(NULL)
    }
    
    pct <- round(((today_total - yesterday_total) / yesterday_total) * 100, 1)
    
    list(pct = pct)
  })
  
  month_change <- reactive({
    
    df <- sheet_data()
    
    df <- df %>% mutate(MonthYear = format(Date, "%Y-%m"))
    
    current_month <- format(Sys.Date(), "%Y-%m")
    
    months <- sort(unique(df$MonthYear))
    current_index <- which(months == current_month)
    
    if(length(current_index) == 0 || current_index == 1){
      return(NULL)
    }
    
    prev_month <- months[current_index - 1]
    
    current_total <- df %>%
      filter(MonthYear == current_month) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    prev_total <- df %>%
      filter(MonthYear == prev_month) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    if(prev_total == 0) return(NULL)
    
    pct <- round(((current_total - prev_total) / prev_total) * 100, 1)
    
    list(pct = pct)
  })
  
  today_spend <- reactive({
    
    df <- sheet_data()
    
    total_today <- df %>%
      filter(Date == Sys.Date()) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    total_today
  })
  
  # DELETE TABLE
  output$delete_table <- renderDT({
    datatable(sheet_data(),
              selection="multiple",
              options=list(pageLength=8))
  })
  
  # SAFE DELETE
  observeEvent(input$confirm_delete, {
    
    selected <- input$delete_table_rows_selected
    
    if(length(selected)==0){
      showNotification("No rows selected", type="error")
      return()
    }
    
    df <- sheet_data()
    df <- df[-selected, ]
    
    sheet_write(df, ss = sheet_url, sheet = sheet_tab)
    
    removeModal()
    showNotification("Deleted Successfully ✅")
    
    refresh_data(refresh_data() + 1)
  })
  
  # 📊 STATS
  stats_data <- reactive({
    
    df <- sheet_data()
    df <- df %>% mutate(MonthYear = format(Date,"%Y-%m"))
    
    current_month <- format(Sys.Date(),"%Y-%m")
    df_current <- df %>% filter(MonthYear==current_month)
    
    total <- sum(df_current$Expense)
    balance <- 20000 - total
    
    highest <- df_current %>%
      group_by(Category) %>%
      summarise(total=sum(Expense)) %>%
      arrange(desc(total)) %>%
      slice(1)
    
    highest_cat <- if(nrow(highest)==0) "N/A" else highest$Category
    highest_amt <- if(nrow(highest)==0) 0 else highest$total
    
    today_day <- as.numeric(format(Sys.Date(),"%d"))
    
    emi_paid <- df_current %>%
      filter(Category=="Finance", `Sub-Category`=="Inverter") %>%
      nrow()>0
    
    if(emi_paid){
      emi_status <- "EMI Paid ✅"; emi_sub <- ""
    } else if(today_day < 5){
      emi_status <- "EMI Due Soon"
      emi_sub <- paste0(5-today_day," days left")
    } else {
      emi_status <- "EMI Overdue ❌"; emi_sub <- "Pay immediately"
    }
    
    list(total=total, balance=balance,
         highest_cat=highest_cat, highest_amt=highest_amt,
         emi_status=emi_status, emi_sub=emi_sub)
  })
  
  # 📊 BUDGET
  budget_data <- reactive({
    df <- sheet_data()
    current_month <- format(Sys.Date(),"%Y-%m")
    
    df_current <- df %>% filter(format(Date,"%Y-%m")==current_month)
    
    actuals <- df_current %>%
      group_by(Category) %>%
      summarise(Spent=sum(Expense))
    
    merge(budget_df, actuals, by="Category", all.x=TRUE) %>%
      mutate(Spent=ifelse(is.na(Spent),0,Spent))
  })
  
  # 📊 RECENT
  recent_txn <- reactive({
    df <- sheet_data() %>% arrange(desc(Date))
    latest_dates <- head(unique(df$Date),2)
    df %>% filter(Date %in% latest_dates)
  })
  
  category_forecast <- reactive({
    
    df <- sheet_data()
    
    df <- df %>%
      mutate(MonthYearDate = as.Date(format(Date, "%Y-%m-01")))
    
    df_cat <- df %>%
      group_by(Category, MonthYearDate) %>%
      summarise(Total = sum(Expense), .groups = "drop") %>%
      arrange(Category, MonthYearDate)
    
    forecast_list <- df_cat %>%
      group_by(Category) %>%
      summarise(
        Last = tail(Total,1),
        Prev = ifelse(n() > 1, tail(Total,2)[1], Last),
        Forecast = Last + (Last - Prev)*0.5,
        .groups = "drop"
      )
    
    forecast_list
  })
  
  output$screen <- renderUI({
    
    if(current_tab()=="home"){
      
      s <- stats_data()
      bd <- budget_data()
      tx <- recent_txn()
      
      div(class="container",
          div(class="header",
              div(style="display:flex;justify-content:space-between;align-items:center;",
                  h4("Expense Analysis"),
                  actionButton("delete_open","🗑️",
                               style="background:white;color:red;border:none;font-size:18px;")
              )
          ),
          
          div(class="grid",
              
              div(class="card",
                  style="background:#dcfce7;",
                  
                  strong(paste0("₹ ", today_spend())),
                  br(),
                  "Today’s Spend",
                  
                  if(!is.null(today_change())){
                    
                    pct <- today_change()$pct
                    
                    color <- ifelse(pct >= 0, "red", "green")
                    sign <- ifelse(pct >= 0, "+", "")
                    arrow <- ifelse(pct >= 0, "⬆", "⬇")
                    
                    div(
                      style=paste0("color:", color, "; font-size:12px; margin-top:5px;"),
                      paste0(arrow, " ", sign, pct, "% vs yesterday")
                    )
                  }
              ),
              
              div(class="card",
                  style="background:#e0f2fe;",
                  
                  strong(paste0("₹ ", s$total)),
                  br(),
                  "Total Spent This Month",
                  
                  if(!is.null(month_change())){
                    
                    pct <- month_change()$pct
                    
                    color <- ifelse(pct >= 0, "red", "green")
                    sign <- ifelse(pct >= 0, "+", "")
                    
                    div(
                      style=paste0("color:", color, "; font-size:12px; margin-top:5px;"),
                      paste0(sign, pct, "% vs last month")
                    )
                  }
              ),
              
              div(class="card",
                  style="background:#f3e8ff;",
                  strong(paste0("₹ ", s$balance)),
                  br(),
                  "Total Balance"
              ),
              
              div(class="card",
                  style="background:#fff7ed;",
                  "Highest spending",
                  br(),
                  s$highest_cat,
                  br(),
                  strong(paste0("₹ ", s$highest_amt))
              )
          ),
          div(class="card",
              style="margin-top:10px; background:#fef9c3;",
              strong(s$emi_status),
              br(),
              s$emi_sub
          ),
          
          div(class="card",
              style="background:#ecfeff; padding:10px;",
              
              div(style="display:flex; flex-direction:column; gap:4px; font-size:12px;",
                  
                  div(textOutput("daily_alert", inline=TRUE)),
                  
                  div(textOutput("smart_advice", inline=TRUE))
              )
          ),
          
          div(class="card",
              div(class="section-header",
                  strong("Budget vs Actual"),
                  actionButton("view_budget","View All >",class="view-btn")),
              lapply(1:min(3, nrow(bd)), function(i){
                
                percent <- ifelse(bd$Budget[i] == 0, 0,
                                  round((bd$Spent[i] / bd$Budget[i]) * 100))
                
                bar_color <- if(percent < 70){
                  "#16a34a"   # green
                } else if(percent < 100){
                  "#f59e0b"   # orange
                } else {
                  "#dc2626"   # red
                }
                
                div(
                  style="margin-bottom:10px;",
                  
                  # Category + value
                  div(style="display:flex;justify-content:space-between;font-size:13px;",
                      span(strong(bd$Category[i])),
                      span(paste0("₹ ", bd$Spent[i], " / ₹ ", bd$Budget[i]))
                  ),
                  
                  # Progress bar
                  div(style="background:#e5e7eb;border-radius:10px;height:10px;",
                      div(style=paste0(
                        "width:", percent, "%;",
                        "background:", bar_color, ";",
                        "height:10px;border-radius:10px;"
                      ))
                  )
                )
              })
          ),
          
          div(class="card",
              div(class="section-header",
                  strong("Recent Transactions"),
                  actionButton("view_txn","More >",class="view-btn")),
              lapply(1:3,function(i){
                div(class="txn",
                    span(paste(tx$Category[i],"₹",tx$Expense[i])),
                    span(format(tx$Date[i],"%b %d"))
                )
              })
          )
      )
    }
    
    else if(current_tab()=="analysis"){
      
      df <- sheet_data()
      months <- unique(format(df$Date, "%b %Y"))
      
      div(class="container",
          div(class="header", h4("Analysis")),
          
          div(class="card",
              fluidRow(
                column(6,
                       div(style="font-size:12px;",
                           selectInput("month_select", "Month",
                                       choices = months,
                                       selected = tail(months, 1),
                                       width = "100%")
                       )
                ),
                column(6,
                       div(style="font-size:12px;",
                           selectInput("analysis_type", "Analysis",
                                       choices = c(
                                         "Monthly Trend",
                                         "Category Expense",
                                         "Sub-Category Expense",
                                         "Household Expense",
                                         "Personal Expense"
                                       ),
                                       selected = "Monthly Trend",
                                       width = "100%")
                       )
                )
              )
          ),
          
          uiOutput("analysis_content")
      )
    }
    
    else if(current_tab()=="emi"){
      
      div(class="container",
          div(class="header", h4("EMI Tracker")),
          
          div(class="card",
              strong("Total Pending EMI"),
              br(),
              textOutput("emi_pending")
          ),
          
          div(class="card",
              DTOutput("emi_table")
          )
      )
    }
    
    else if(current_tab()=="budget"){
      
      bd <- budget_data() %>%
        mutate(Percent = ifelse(Budget == 0, 0, (Spent / Budget) * 100)) %>%
        arrange(desc(Percent))
      
      div(class="container",
          
          div(class="header",
              actionButton("back","< Back"),
              h4("Full Budget")
          ),
          
          # 🔴 ALERT
          if(nrow(bd %>% filter(Percent > 100)) > 0){
            div(class="card",
                style="background:#fee2e2;color:#991b1b;",
                strong("⚠ Over Budget Alert"),
                br(),
                paste(bd %>% 
                        filter(Percent > 100) %>% 
                        pull(Category),
                      collapse=", ")
            )
          },
          
          # 📊 LIST
          lapply(1:nrow(bd), function(i){
            
            percent <- round(bd$Percent[i])
            
            bar_color <- if(percent < 70){
              "#16a34a"
            } else if(percent < 100){
              "#f59e0b"
            } else {
              "#dc2626"
            }
            
            div(class="card",
                
                div(style="display:flex;justify-content:space-between;",
                    span(strong(bd$Category[i])),
                    span(paste0("₹ ", bd$Spent[i], " / ₹ ", bd$Budget[i]))
                ),
                
                br(),
                
                div(style="background:#e5e7eb;border-radius:10px;height:12px;",
                    div(style=paste0(
                      "width:", percent, "%;",
                      "background:", bar_color, ";",
                      "height:12px;border-radius:10px;text-align:right;color:white;font-size:10px;padding-right:5px;"
                    ),
                    paste0(percent, "%")
                    )
                )
            )
          })
      )
    }
    
    else if(current_tab()=="transactions"){
      tx <- recent_txn()
      div(class="container",
          div(class="header", actionButton("back","< Back"), h4("All Transactions")),
          actionButton("delete_open","🗑️ Delete Expense",
                       style="background:red;color:white;width:100%;margin-bottom:10px;"),
          lapply(1:nrow(tx),function(i){
            div(class="card",
                paste(tx$Category[i],"-",tx$`Sub-Category`[i]),
                br(),paste0("₹ ",tx$Expense[i]))
          })
      )
    }
  })
  
  output$daily_alert <- renderText({
    
    df <- sheet_data()
    
    current_month <- format(Sys.Date(), "%Y-%m")
    
    total_spent <- df %>%
      filter(format(Date, "%Y-%m") == current_month) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    total_budget <- sum(budget_df$Budget)
    
    usage <- (total_spent / total_budget) * 100
    
    if(usage > 90){
      paste0("🚨 ", round(usage), "% of budget used (Critical)")
    } else if(usage > 75){
      paste0("⚠ ", round(usage), "% of budget used (Warning)")
    } else {
      paste0("✅ ", round(usage), "% of budget used")
    }
  })
  
  output$smart_advice <- renderText({
    
    df <- sheet_data()
    
    df_month <- df %>%
      filter(format(Date, "%Y-%m") == format(Sys.Date(), "%Y-%m")) %>%
      group_by(Category) %>%
      summarise(Total = sum(Expense), .groups="drop") %>%
      arrange(desc(Total))
    
    if(nrow(df_month) == 0) return(NULL)
    
    top_cat <- df_month$Category[1]
    
    paste0("💡 Reduce ", top_cat, " spending to improve savings")
  })
  
  output$cat_total <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    total <- df %>%
      filter(format(Date, "%b %Y") == input$month_select) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    paste0("₹ ", format(total, big.mark = ","))
  })
  
  output$cat_compare <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    months <- sort(unique(format(df$Date, "%b %Y")))
    
    current_index <- which(months == input$month_select)
    
    if(length(current_index) == 0 || current_index == 1){
      return("No previous month data")
    }
    
    current_month <- months[current_index]
    previous_month <- months[current_index - 1]
    
    current_total <- df %>%
      filter(format(Date, "%b %Y") == current_month) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    previous_total <- df %>%
      filter(format(Date, "%b %Y") == previous_month) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    diff <- current_total - previous_total
    
    if(diff > 0){
      paste0("⬆ Increased by ₹ ", format(diff, big.mark=","))
    } else if(diff < 0){
      paste0("⬇ Decreased by ₹ ", format(abs(diff), big.mark=","))
    } else {
      "No change from last month"
    }
  })
  
  output$bar_chart <- renderPlotly({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    df_filtered <- df %>%
      filter(MonthYear == input$month_select) %>%
      group_by(Category) %>%
      summarise(TotalExpense = sum(Expense, na.rm = TRUE), .groups = "drop") %>%
      arrange(desc(TotalExpense))
    
    p <- ggplot(
      df_filtered,
      aes(
        x = reorder(Category, TotalExpense),
        y = TotalExpense,
        text = paste("Category:", Category, "<br>Total:", TotalExpense)
      )
    ) +
      geom_col(fill = "#009E73") +
      coord_flip() +
      theme_minimal() +
      theme(
        axis.title.x = element_blank(),
        axis.title.y = element_blank()
      )
    
    ggplotly(p, tooltip = "text")
  })
  
  month_projection <- reactive({
    
    df <- sheet_data()
    
    today <- Sys.Date()
    
    current_month <- format(today, "%Y-%m")
    
    df_current <- df %>%
      filter(format(Date, "%Y-%m") == current_month)
    
    if(nrow(df_current) == 0) return(NULL)
    
    # total spent so far
    total_spent <- sum(df_current$Expense, na.rm = TRUE)
    
    # days passed
    days_passed <- as.numeric(format(today, "%d"))
    
    # total days in month
    total_days <- as.numeric(format(
      as.Date(paste0(format(today, "%Y-%m"), "-01")) + 32, "%d"
    ))
    
    # daily average
    daily_avg <- total_spent / days_passed
    
    # projection
    projected <- daily_avg * total_days
    
    list(
      projected = projected,
      current = total_spent
    )
  })
  
  
  
  forecast_calc <- reactive({
    
    df <- sheet_data()
    
    df_all <- df %>%
      group_by(MonthYearDate) %>%
      summarise(Total = sum(Expense), .groups = "drop") %>%
      arrange(MonthYearDate)
    
    df_completed <- df_all %>%
      filter(MonthYearDate < as.Date(format(Sys.Date(), "%Y-%m-01")))
    
    if(nrow(df_completed) < 2){
      return(NULL)
    }
    
    last_n <- tail(df_completed$Total, 3)
    avg_forecast <- mean(last_n, na.rm = TRUE)
    
    trend <- tail(df_completed$Total,1) - tail(df_completed$Total,2)[1]
    
    forecast_value <- avg_forecast + (0.5 * trend)
    
    last_actual <- tail(df_completed$Total,1)
    
    list(
      forecast = forecast_value,
      last_actual = last_actual,
      df_completed = df_completed
    )
  })
  
