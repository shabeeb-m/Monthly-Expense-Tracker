    # Calculate mean & sd
    avg <- mean(df$Expense, na.rm = TRUE)
    sd_val <- sd(df$Expense, na.rm = TRUE)
    
    # threshold (mean + 2*sd)
    threshold <- avg + (2 * sd_val)
    
    # find anomalies (recent ones)
    anomalies <- df %>%
      filter(Expense > threshold) %>%
      arrange(desc(Date)) %>%
      head(1)
    
    if(nrow(anomalies) == 0) return(NULL)
    
    paste0(
      "🚨 Unusual spend detected: ₹ ",
