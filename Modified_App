    req(input$month_select)
    
    df <- sheet_data()
    
    household_categories <- c("To Home","Meat & Seafood","Groceries","Utility")
    
    df_filtered <- df %>%
      filter(
        format(Date, "%b %Y") == input$month_select,
        Category %in% household_categories
      ) %>%
      group_by(Category) %>%
      summarise(TotalExpense = sum(Expense, na.rm = TRUE), .groups = "drop") %>%
      arrange(desc(TotalExpense))
    
    p <- ggplot(
      df_filtered,
      aes(
        x = reorder(Category, TotalExpense),
        y = TotalExpense,
        text = paste("Category:", Category, "<br>Total: ₹", TotalExpense)
      )
    ) +
      geom_col(fill = "#2563eb") +
      coord_flip() +
      theme_minimal() +
      theme(
        axis.title.x = element_blank(),
        axis.title.y = element_blank()
      )
    
    ggplotly(p, tooltip = "text")
  })
  
  output$personal_total <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    personal_categories <- c("Outside Food","Personal","Transport","Sweets","Leisure","Skin Care")
    
    total <- df %>%
      filter(format(Date, "%b %Y") == input$month_select,
             Category %in% personal_categories) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    paste0("₹ ", format(total, big.mark = ","))
  })
  
  output$personal_compare <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    personal_categories <- c("Outside Food","Personal","Transport","Sweets","Leisure","Skin Care")
    
    months <- sort(unique(format(df$Date, "%b %Y")))
    
    current_index <- which(months == input$month_select)
    
    if(length(current_index) == 0 || current_index == 1){
      return("No previous month data")
    }
    
    current_month <- months[current_index]
    previous_month <- months[current_index - 1]
    
    current_total <- df %>%
      filter(format(Date, "%b %Y") == current_month,
             Category %in% personal_categories) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    previous_total <- df %>%
      filter(format(Date, "%b %Y") == previous_month,
             Category %in% personal_categories) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    diff <- current_total - previous_total
    
    if(diff > 0){
      paste0("⬆ Increased by ₹ ", format(diff, big.mark=","))
    } else if(diff < 0){
      paste0("⬇ Decreased by ₹ ", format(abs(diff), big.mark=","))
    } else {
      "No change from last month"
    }
  })
  
  output$personal_chart <- renderPlotly({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    personal_categories <- c("Outside Food","Personal","Transport","Sweets","Leisure","Skin Care")
    
    df_filtered <- df %>%
      filter(format(Date, "%b %Y") == input$month_select,
             Category %in% personal_categories) %>%
      group_by(Category) %>%
      summarise(Total = sum(Expense), .groups = "drop") %>%
      arrange(desc(Total))
    
    p <- ggplot(df_filtered,
                aes(x = reorder(Category, Total),
                    y = Total,
                    text = paste("Category:", Category, "<br>Total: ₹", Total))) +
      geom_col(fill = "#f97316") +
      coord_flip() +
      theme_minimal()
    
    ggplotly(p, tooltip = "text")
  })
  
  output$personal_pie <- renderPlotly({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    personal_categories <- c("Outside Food","Personal","Transport","Sweets","Leisure","Skin Care")
    
    df_filtered <- df %>%
      filter(format(Date, "%b %Y") == input$month_select,
             Category %in% personal_categories) %>%
      group_by(Category) %>%
      summarise(Total = sum(Expense), .groups = "drop")
    
    plot_ly(
      df_filtered,
      labels = ~Category,
      values = ~Total,
      type = "pie"
    )
  })
  
  emi_data <- reactive({
    
    df <- sheet_data()
    
    emi_df <- df %>% 
      filter(`Sub-Category` %in% c("Skillovilla EMI","Dental","Inverter")) %>% 
      group_by(`Sub-Category`) %>% 
      summarise(Paid = sum(Expense, na.rm = TRUE), .groups = "drop") %>% 
      mutate(
        Due = case_when(
          `Sub-Category` == "Skillovilla EMI" ~ 41262,
          `Sub-Category` == "Dental" ~ 24000,
          `Sub-Category` == "Inverter" ~ 10000
        ),
        Remaining = Due - Paid,
        Paid_Percent = round((Paid / Due) * 100, 1),
        
        Status = case_when(
          Remaining <= 0 ~ "Paid",
          Paid > 0 ~ "Partial",
          TRUE ~ "Pending"
        ),
        
        Item = `Sub-Category`
      ) %>% 
      select(Item, Due, Paid, Remaining, Paid_Percent, Status) %>% 
      arrange(desc(Due))
    
    emi_df
  })
  
  output$emi_table <- renderDT({
    
    df <- emi_data()
    
    # Compact progress bar
    df$Progress <- paste0(
      '<div style="background:#e5e7eb;border-radius:8px;height:16px;">',
      '<div style="width:', df$Paid_Percent, '%;
                 background:#16a34a;
                 color:white;
                 text-align:center;
                 font-size:10px;
                 line-height:16px;
                 border-radius:8px;">',
      df$Paid_Percent, '%</div></div>'
    )
    
    # Compact colored status
    df$Status <- ifelse(df$Status == "Paid",
                        '<span style="color:green;font-size:11px;">●</span>',
                        ifelse(df$Status == "Partial",
                               '<span style="color:orange;font-size:11px;">●</span>',
                               '<span style="color:red;font-size:11px;">●</span>'))
    
    datatable(
      df[, c("Item","Due","Paid","Remaining","Progress","Status")],
      escape = FALSE,
      rownames = FALSE,
      options = list(
        pageLength = 5,
        dom = 't',
        autoWidth = TRUE
      ),
      class = "compact stripe"
    )
  })
  
  output$emi_pending <- renderText({
    
    df <- emi_data()
    
    total_pending <- sum(df$Remaining, na.rm = TRUE)
    
    if(total_pending == 0){
      "All EMIs Cleared ✅"
    } else {
      paste0("₹ ", format(total_pending, big.mark = ","), " Pending")
    }
  })
  
}

