  #     pull(MonthYear)
  #   
  #   if(length(months) == 0) return()
  #   
  #   updateSelectInput(
  #     session,
  #     "month_select",
  #     choices = months,
  #     selected = tail(months, 1)
  #   )
  #   
  # }, ignoreInit = FALSE)
  # 
  # observe({
  #   print(head(sheet_data()))
  # })
  # 
  output$bar_chart <- renderPlotly({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    df_filtered <- df %>%
      filter(MonthYear == input$month_select) %>%
      group_by(Category) %>%
      summarise(TotalExpense = sum(Expense, na.rm = TRUE), .groups = "drop") %>%
      arrange(desc(TotalExpense))
    
    p <- ggplot(
      df_filtered,
      aes(
        x = reorder(Category, TotalExpense),
        y = TotalExpense,
        text = paste("Category:", Category, "<br>Total:", TotalExpense)
      )
    ) +
      geom_col(fill = "#009E73") +
      coord_flip() +
      theme_minimal() +
      theme(
        axis.title.x = element_blank(),
        axis.title.y = element_blank()
      )
    
    ggplotly(p, tooltip = "text")
  })
  
  output$subcat_total <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    total <- df %>%
      filter(format(Date, "%b %Y") == input$month_select) %>%
      summarise(sum(Expense, na.rm = TRUE)) %>%
      pull()
    
    paste0("₹ ", format(total, big.mark = ","))
  })
  
  output$subcat_compare <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    months <- sort(unique(format(df$Date, "%b %Y")))
    
    current_index <- which(months == input$month_select)
    
    if(length(current_index) == 0 || current_index == 1){
      return("No previous month data")
    }
    
    current_month <- months[current_index]
    previous_month <- months[current_index - 1]
    
    current_total <- df %>%
      filter(format(Date, "%b %Y") == current_month) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    previous_total <- df %>%
      filter(format(Date, "%b %Y") == previous_month) %>%
      summarise(sum(Expense)) %>%
      pull()
    
    diff <- current_total - previous_total
    
    if(diff > 0){
      paste0("⬆ Increased by ₹ ", format(diff, big.mark=","))
    } else if(diff < 0){
      paste0("⬇ Decreased by ₹ ", format(abs(diff), big.mark=","))
    } else {
      "No change from last month"
    }
  })
  
  output$subcat_chart <- renderPlotly({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    df_filtered <- df %>%
      filter(format(Date, "%b %Y") == input$month_select) %>%
      group_by(`Sub-Category`) %>%
      summarise(Total = sum(Expense), .groups = "drop") %>%
      arrange(desc(Total))
    
    p <- ggplot(
      df_filtered,
      aes(
        x = Total,
        y = reorder(`Sub-Category`, Total),
        text = paste("Sub-Category:", `Sub-Category`, "<br>Total: ₹", Total)
      )
    ) +
      geom_col(fill = "#0ea5e9") +
      theme_minimal() +
      theme(
        axis.title.x = element_blank(),
        axis.title.y = element_blank()
      )
    
    ggplotly(p, tooltip = "text")
  })
  
  output$subcat_pie <- renderPlotly({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    df_filtered <- df %>%
      filter(format(Date, "%b %Y") == input$month_select) %>%
      group_by(`Sub-Category`) %>%
      summarise(Total = sum(Expense), .groups = "drop")
    
    plot_ly(
      df_filtered,
      labels = ~`Sub-Category`,
      values = ~Total,
      type = "pie"
    )
  })
  
  output$household_total <- renderText({
    
    req(input$month_select)
    
    df <- sheet_data()
    
    household_categories <- c("To Home","Meat & Seafood","Groceries","Utility")
    
    current_total <- df %>%
      filter(format(Date, "%b %Y") == input$month_select,
             Category %in% household_categories) %>%
      summarise(Total = sum(Expense, na.rm = TRUE)) %>%
      pull(Total)
    
